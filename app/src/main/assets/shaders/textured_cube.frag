#version 300 es
precision mediump float;
// ═══════════════════════════════════════════════════════════
// 纹理正方体 · 片元着色器
//
// 对应文档：「纹理 — 各种表面素材图」
//
// texture() 函数的工作：
//   拿到这个像素的 UV 坐标 → 去纹理图上找对应位置 → 取出颜色
//   就像拿着地图上的坐标找到对应的地点
//
// 这里用的是「颜色贴图(Albedo)」— 最基础的表面底色纹理
// ═══════════════════════════════════════════════════════════

// 2D 纹理采样器 — 绑定了我们的棋盘格纹理
uniform sampler2D uTexture;

// 从顶点着色器插值得到的 UV 坐标
in vec2 vUV;

out vec4 fragColor;

void main() {
    // 用 UV 坐标从纹理中采样颜色
    fragColor = texture(uTexture, vUV);
}
