#version 300 es
// ═══════════════════════════════════════════════════════════
// 基础正方体 · 顶点着色器 (Vertex Shader)
//
// 对应文档：「顶点着色器 — 确定每个焊接点在空间中的位置」
// 功能：通过 MVP 矩阵把每个顶点从模型坐标变换到屏幕坐标
//
// MVP 变换流程（文档第四章）：
//   模型空间(零件仓库) → 世界空间(总装车间)
//   → 摄像机空间(用户视角) → 屏幕
// ═══════════════════════════════════════════════════════════

// MVP 矩阵 = Projection × View × Model
// 一次性完成「零件定位 → 用户视角 → 拍照投影」三步变换
uniform mat4 uMVP;

// 顶点输入属性（从 CPU 传入的顶点数据）
layout(location = 0) in vec3 aPos;    // 顶点位置 (x, y, z)
layout(location = 1) in vec4 aColor;  // 顶点颜色 (r, g, b, a)

// 传递给片元着色器的数据（GPU 会自动插值）
out vec4 vColor;

void main() {
    // MVP 变换：将 3D 模型坐标投影到 2D 屏幕坐标
    // 文档：「把模型的每个顶点变换到正确的屏幕位置」
    gl_Position = uMVP * vec4(aPos, 1.0);

    // 颜色直接传递，每个面不同颜色方便观察三角形拼接
    vColor = aColor;
}
