#version 300 es
// ═══════════════════════════════════════════════════════════
// 纹理正方体 · 顶点着色器
//
// 对应文档：「UV 映射 — 把平面纹理贴到立体表面」
//
// UV 坐标的作用：
//   模型是立体的，纹理是平面图片。
//   每个顶点记录一对 (u, v) 坐标，标记它对应纹理图上的哪个位置。
//   就像给车贴车衣，要知道哪块对应引擎盖、哪块对应车门。
// ═══════════════════════════════════════════════════════════

uniform mat4 uMVP;

layout(location = 0) in vec3 aPos;   // 顶点位置
layout(location = 1) in vec2 aUV;    // 纹理坐标 (u, v)

// UV 坐标传递给片元着色器，GPU 在三角形内部自动插值
out vec2 vUV;

void main() {
    gl_Position = uMVP * vec4(aPos, 1.0);
    vUV = aUV;
}
