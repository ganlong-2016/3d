#version 300 es
precision mediump float;
// ═══════════════════════════════════════════════════════════
// 基础正方体 · 片元着色器 (Fragment Shader)
//
// 对应文档：「片元着色器 — 给白车身的每一寸表面喷漆上色」
// 功能：对每个像素输出最终颜色
//
// 这是最简单的着色器 — 直接使用顶点插值颜色
// 不做任何光照计算，相当于「白车身喷了纯色漆」
// ═══════════════════════════════════════════════════════════

// 从顶点着色器插值得到的颜色
// GPU 光栅化时会自动对三角形内部的像素做平滑颜色过渡
in vec4 vColor;

// 最终输出 → 写入帧缓冲 → 显示到屏幕
// 文档：「帧缓冲 — 最终画面的存储区」
out vec4 fragColor;

void main() {
    fragColor = vColor;
}
