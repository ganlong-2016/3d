#version 300 es
// ═══════════════════════════════════════════════════════════
// 天空盒 · 顶点着色器
//
// 对应文档：「天空盒 — 展厅四周的巨幅背景画」
//
// 天空盒是一个包围整个场景的大立方体。
// 顶点位置同时作为立方体贴图(CubeMap)的采样方向。
//
// 关键技巧：gl_Position = pos.xyww
//   让深度始终为 1.0（最远处），天空盒永远在所有物体后面
// ═══════════════════════════════════════════════════════════

// 视图-投影矩阵（去掉了平移分量，只保留旋转）
// 这样无论摄像机移到哪，天空盒都像在「无限远处」
uniform mat4 uVP;

layout(location = 0) in vec3 aPos;

// 方向向量传递给片元着色器用于 CubeMap 采样
out vec3 vDir;

void main() {
    // 顶点位置直接作为立方体贴图的采样方向
    vDir = aPos;

    vec4 pos = uVP * vec4(aPos, 1.0);

    // xyww 技巧：设置 z = w，透视除法后 z/w = 1.0
    // 确保天空盒始终在最远处的深度平面
    gl_Position = pos.xyww;
}
