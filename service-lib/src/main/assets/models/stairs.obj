# ═══════════════════════════════════════════════════════════
# 楼梯 (Stairs) — 法线与光照的最佳演示模型
# ═══════════════════════════════════════════════════════════
#
# 16 个顶点 · 28 个三角面
#
# 为什么楼梯能直观展示光照原理？
#
#   楼梯有朝向不同方向的面：
#     · 阶面(水平) — 法线朝上(0,1,0)，接收从上方来的光线 → 亮
#     · 踢面(垂直) — 法线朝前(0,0,1)，光线侧面照射 → 较暗
#     · 侧面       — 法线朝左右，光照角度又不同
#
#   转动模型时，可以清晰看到：
#     法线方向 vs 光线方向的夹角 → 决定了面的亮度
#     这就是文档说的「漫反射 = cos(法线, 光线方向)」
#
# 结构：3 级台阶，沿 Z 轴向后递增高度
#   第1级(前)：最矮  y 到 -0.3
#   第2级(中)：中等  y 到 -0.1
#   第3级(后)：最高  y 到  0.1
# ═══════════════════════════════════════════════════════════

# ─── 左侧轮廓顶点 (x = -0.3) ───
v -0.3 -0.5  0.6
v -0.3 -0.3  0.6
v -0.3 -0.3  0.3
v -0.3 -0.1  0.3
v -0.3 -0.1  0.0
v -0.3  0.1  0.0
v -0.3  0.1 -0.3
v -0.3 -0.5 -0.3

# ─── 右侧轮廓顶点 (x = 0.3) ───
v  0.3 -0.5  0.6
v  0.3 -0.3  0.6
v  0.3 -0.3  0.3
v  0.3 -0.1  0.3
v  0.3 -0.1  0.0
v  0.3  0.1  0.0
v  0.3  0.1 -0.3
v  0.3 -0.5 -0.3

# ─── 法线 (6个方向) ───
vn  0  0  1
vn  0  1  0
vn  0  0 -1
vn  0 -1  0
vn -1  0  0
vn  1  0  0

# ─── 3 个踢面(竖直面，法线朝前 +Z) ───
# 第1级正面
f 1//1 9//1 10//1
f 1//1 10//1 2//1
# 第2级正面(台阶上升处)
f 3//1 11//1 12//1
f 3//1 12//1 4//1
# 第3级正面
f 5//1 13//1 14//1
f 5//1 14//1 6//1

# ─── 3 个阶面(水平面，法线朝上 +Y) ───
# 第1级顶面
f 2//2 10//2 11//2
f 2//2 11//2 3//2
# 第2级顶面
f 4//2 12//2 13//2
f 4//2 13//2 5//2
# 第3级顶面
f 6//2 14//2 15//2
f 6//2 15//2 7//2

# ─── 背面 (-Z) ───
f 7//3 15//3 16//3
f 7//3 16//3 8//3

# ─── 底面 (-Y) ───
f 1//4 8//4 16//4
f 1//4 16//4 9//4

# ─── 左侧面 (-X) — 楼梯形剪影 ───
f 1//5 2//5 3//5
f 1//5 3//5 4//5
f 1//5 4//5 5//5
f 1//5 5//5 6//5
f 1//5 6//5 7//5
f 1//5 7//5 8//5

# ─── 右侧面 (+X) — 楼梯形剪影 ───
f 9//6 16//6 15//6
f 9//6 15//6 14//6
f 9//6 14//6 13//6
f 9//6 13//6 12//6
f 9//6 12//6 11//6
f 9//6 11//6 10//6
